{
  "version": 2,
  "builds": [
    {
      "src": "api/index.php",
      "use": "vercel-php@0.7.1"
    },
    {
      "src": "api/movie.php",
      "use": "vercel-php@0.7.1"
    }
  ],
  "routes": [
    {
      "src": "/movie/(?<id>[^/]+)",
      "dest": "/api/movie.php?id=$id"
    },
    {
      "src": "/movie",
      "dest": "/api/movie.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
